# CareStickers environment configuration.
# Copy to `.env` and fill in. `.env*` is gitignored (except this example). NEVER commit real secrets.

# ----------------------------------------------------------------------------
# API server (Express)
# ----------------------------------------------------------------------------

# PostgreSQL connection string.
# Supabase: use the Supavisor SESSION pooler (port 5432), which preserves per-connection
# behaviour for the long-lived pg Pool and provides IPv4 connectivity:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Local Docker Postgres: postgres://care:care@localhost:5432/carestickers
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# TLS toggle for the database connection. Supabase requires TLS (leave unset / any non-"disable").
# Set to "disable" for local Docker Postgres, which does not speak TLS.
# PGSSL=disable

# Supabase Auth token verification and `@supabase/server` client setup.
# Copy publishable/secret keys from the Supabase dashboard Connect dialog — never commit real secrets.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only: bypasses RLS via ctx.supabaseAdmin (required for auth: "secret" and admin clients).
SUPABASE_SECRET_KEY=sb_secret_...
# JWT verification for auth: "user". Derived from SUPABASE_URL when unset:
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Or inline JWKS JSON (takes priority over SUPABASE_JWKS_URL):
# SUPABASE_JWKS={"keys":[...]}

# Comma-separated emails granted the admin role (also enforced at request time on the server).
# Local seed admin: admin@carestickers.local (password123) — see supabase/seed.sql.
ADMIN_EMAILS=

# Web origin(s) for CORS. One or more comma-separated origins users open in a browser.
FRONTEND_URL=http://localhost:3000
# Extra allowed CORS origins (comma-separated), e.g. staging URLs.
CORS_ORIGINS=
# Set to "false" to disable auto-allowing Capacitor WebView origins.
# ALLOW_CAPACITOR_ORIGINS=true

# API port (default 3001).
# PORT=3001

# Optional: on server startup, apply supabase/migrations/0001_initial_schema.sql once
# (handy for local dev; prefer `supabase db push` / `db reset` otherwise).
# APPLY_SCHEMA=true

# ----------------------------------------------------------------------------
# Frontend (Vite) - VITE_ vars are bundled into the client and are public
# ----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# The Supabase anon/publishable key is public by design (safe with the API enforcing access).
VITE_SUPABASE_ANON_KEY=<your-anon-key>
# Emails treated as admins in the UI (align with ADMIN_EMAILS).
# Local seed: admin@carestickers.local
VITE_ADMIN_EMAILS=
# Required for Capacitor / mobile builds: full API base URL WITHOUT trailing slash.
# Leave unset for same-origin web deployments.
# VITE_API_BASE=https://api.example.com

# ----------------------------------------------------------------------------
# Supabase CLI (local / CI secrets - used by `supabase link` / `db push`)
# Keep these out of the repo; never expose the service_role key to the frontend.
# ----------------------------------------------------------------------------

# SUPABASE_ACCESS_TOKEN=     # Personal Access Token for `supabase login`/CI — NOT a project API key.
#                           # Create at https://supabase.com/dashboard/account/tokens
#                           # Format: sbp_ + 40 lowercase hex characters (shown once at creation).
# SUPABASE_DB_PASSWORD=      # database password for `supabase link` / `db push`

# Auth provider secrets consumed by supabase/config.toml env() substitution (local stack).
# In the hosted project these live in the Supabase dashboard instead.
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# ----------------------------------------------------------------------------
# Local Docker Postgres overrides (docker-compose.yml)
# ----------------------------------------------------------------------------
# POSTGRES_USER=care
# POSTGRES_PASSWORD=care
# POSTGRES_DB=carestickers
# POSTGRES_PORT=5432
# APP_PORT=3001
